# AWS Credentials for CryptoPulse Data Lakehouse Project
# These credentials are used to access AWS services such as S3 for storing and retrieving crypto data
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=your-bucket-name

# Athena Configuration
# Used by both the Airflow pipeline and Streamlit dashboard
# ATHENA_DATABASE should point to your Gold layer database where analytics tables are stored
ATHENA_DATABASE=gold_layer
ATHENA_S3_STAGING_DIR=s3://your-bucket-name/athena-staging/

# CoinGecko API URL for fetching cryptocurrency data
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=your-coingecko-api-key

# PostgreSQL Credentials for Airflow Metadata Database
# IMPORTANT: If your password contains special characters, URL-encode them:
# @ = %40, . = %2E, * = %2A, / = %2F, : = %3A, etc.
# Example: password @MyPass123. → %40MyPass123%2E
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-url-encoded
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# NOTE: For Streamlit Cloud deployment, add these same variables as Secrets:
# See README.md section "Live Dashboard - Streamlit Cloud Deployment" for details
# Streamlit Cloud does NOT read .env files - use their Secrets manager instead!
