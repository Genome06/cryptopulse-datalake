#Duplicate of .env file with example values. Rename to .env and fill in your actual AWS credentials.
#Dont Forget to uncomment the lines and replace the values with your actual AWS credentials.

# These credentials are used to access AWS services such as S3 for storing and retrieving crypto data
#AWS_ACCESS_KEY_ID=your_access_key_id
#AWS_SECRET_ACCESS_KEY=your_secret_access_key
#AWS_REGION=your_aws_region
#AWS_BUCKET_NAME=your_s3_bucket_name

# CoinGecko API URL for fetching cryptocurrency data
#COINGECKO_BASE_URL=your_coingecko_api_url
#COINGECKO_API_KEY=your_coingecko_api_key